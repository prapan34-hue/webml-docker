# ====== คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าก่อนรัน ======
# คำสั่ง:  cp .env.example .env

# PostgreSQL credentials (อย่า commit ไฟล์ .env จริงขึ้น git)
POSTGRES_USER=mluser
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=mlpredictions

# พอร์ตที่ map ออกมาที่เครื่อง host
WEB_PORT=8080
ML_API_PORT=8000
